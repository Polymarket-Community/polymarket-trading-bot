# Copy into .env (optional) — [@slackgram/logger](https://www.npmjs.com/package/@slackgram/logger)
# Console
# NODE_ENV=development
# LOG_LEVEL=info
# LOG_DEBUG=false
# LOG_SILENT=false
# LOG_COLORS=1

# File logging (creates logs/ under cwd)
# LOG_FILE=true
# LOG_FILE_PATH=logs/bot.log
# LOG_ROTATION=1D
# LOG_MAX_FILES=7
# LOG_FLUSH_MS=2000
# LOG_PRETTY_JSON=1

# Webhooks — errors by default (MB_LOG_HOOK_LEVEL)
# MB_LOG_HOOK_LEVEL=error
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
